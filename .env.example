NODE_ENV=development
API_PORT=3000
WEB_PORT=18081
WEB_ORIGIN=http://localhost:18081
SQLITE_PATH=.data/sengoku.sqlite
SESSION_SECRET=development-only-change-me
LOG_LEVEL=info
# fal.ai API key for the offline terrain-generation pipeline (packages/terrain). Not needed at runtime.
FAL_KEY=
# Directory for terrain pipeline outputs (intermediates + final webp). Each map gets a subdir.
TERRAIN_OUT_DIR=/mnt/ssd_pool/ssd_set/terrain-gen
